generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  organizer
  coach
  admin
}

model User {
  id                    Int       @id @default(autoincrement())
  full_name             String
  phone_number          String?   @unique
  email                 String    @unique
  password_hash         String
  avatar_url            String?
  gender                String?
  age                   Int?
  birth_date            DateTime? @db.Date
  city                  String?
  bio                   String?
  role                  Role      @default(user)
  organizer_verified_at DateTime?
  coach_verified_at     DateTime?
  created_at            DateTime  @default(now())
  last_login            DateTime?

  comments Comment[]
}

model Comment {
  id                Int      @id @default(autoincrement())
  trail_id          Int
  user_id           Int
  comment_text      String
  is_approved       Boolean  @default(false)
  parent_comment_id Int?
  created_at        DateTime @default(now())

  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent_comment Comment?  @relation("CommentReplies", fields: [parent_comment_id], references: [id], onDelete: SetNull)
  replies        Comment[] @relation("CommentReplies")

  @@index([trail_id])
  @@index([user_id])
  @@index([parent_comment_id])
}
